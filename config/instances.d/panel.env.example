# Инстанс WAL-архивации: панель Remnawave.
# Скопируйте в /opt/rw-backup-restore/instances.d/panel.env и поправьте значения.

INST_ENABLED="true"
INST_KIND="panel"

# Контейнер PostgreSQL панели (в стандартной установке Remnawave — remnawave-db).
INST_CONTAINER="remnawave-db"

# Compose-файл панели и имя сервиса БД в нём.
INST_COMPOSE_FILE="/opt/remnawave/docker-compose.yml"
INST_COMPOSE_SERVICE="remnawave-db"

# Доступ к БД (тот же пользователь, что в DB_USER оригинального config.env).
INST_PGUSER="postgres"
INST_PGDATABASE="postgres"

# Максимум секунд, через которые недописанный WAL-сегмент принудительно
# закрывается и уходит в архив. Это ваш RPO при простое: 300 = потеря максимум
# 5 минут изменений. Меньше значение — больше мелких сегментов в S3.
INST_ARCHIVE_TIMEOUT="300"

# ПЕРИОДИЧНОСТЬ (задаётся пользователем). Для каждого таймера — ЛИБО интервал,
# ЛИБО список конкретных времён (любое количество, HH:MM или HH:MM:SS,
# через пробел/запятую). Если задан список — он приоритетнее интервала.
# Базовый бэкап панели — раз в сутки НОЧЬЮ, отдельно от логического дампа (03:00),
# чтобы две тяжёлые операции не шли одновременно. Плюс сработает джиттер парка.
INST_BASEBACKUP_TIMES="04:30"         # конкретные времена: "04:30" или "04:30 16:30"
#INST_BASEBACKUP_INTERVAL_HOURS="24"  # запасной режим: каждые N часов (если TIMES пуст)
INST_WAL_SHIP_INTERVAL_MIN="1"        # отправка WAL из спула: каждые N минут...
#INST_WAL_SHIP_TIMES=""               # ...или по временам (растит RPO — сегменты ждут в спуле)
#INST_SCHEDULE_TZ=""                  # зона для *_TIMES: пусто = локальная сервера; "UTC"; "Europe/Amsterdam"

# После изменения расписания примените: rw-backup-full wal-timers <инстанс>

# Хранение: базовые бэкапы считаются ШТУКАМИ, WAL удаляется автоматически
# только до границы самого старого хранимого базового бэкапа.
INST_LOCAL_BASEBACKUP_KEEP="2"
INST_S3_BASEBACKUP_KEEP="7"

# Мягкий лимит локального WAL-архива в ГБ (только алерт, без удаления).
#INST_LOCAL_WAL_MAX_GB="20"

# Таблицы для контрольных запросов в песочнице (через пробел, schema.table).
INST_VERIFY_TABLES="public.users public.nodes"

# Шифрование age (публичный ключ в FULL_AGE_RECIPIENT в rw-backup-full.env).
INST_ENCRYPT="false"
