# Внешний S3-бэкенд. Файлов может быть сколько угодно: s3.d/<имя>.env
# У каждого бэкенда СВОИ реквизиты, набор категорий и сроки хранения.
B_ENABLED="true"
B_ENDPOINT="https://s3.example.com"       # пусто для AWS
B_BUCKET="my-backups"
B_ACCESS_KEY=""
B_SECRET_KEY=""
B_REGION="us-east-1"
B_PREFIX="rw-backup-full"

# Какие категории заливать в ЭТОТ бэкенд:
B_UPLOAD_PANEL="true"        # remnawave_backup_*.tar.gz
B_UPLOAD_CUSTOM="true"       # custom_bot_*.tar.gz
B_UPLOAD_WAL="true"          # базовые бэкапы + WAL (PITR)

# Хранение (индивидуально для этого бэкенда):
B_RETENTION_PANEL_DAYS="10"
B_RETENTION_CUSTOM_DAYS="10"
B_BASEBACKUP_KEEP="7"        # WAL чистится по границе этих бэкапов автоматически
B_RETENTION_MIN_KEEP="3"     # минимум логических архивов, защищённых от удаления
