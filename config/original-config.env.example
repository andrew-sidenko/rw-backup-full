# /opt/rw-backup-restore/config.env
# Это пример ОРИГИНАЛЬНОГО конфига rw-backup.
# rw-backup-full НЕ хранит здесь свои параметры, но читает отсюда Telegram/S3.

# Способ доставки для оригинального rw-backup и, если FULL_UPLOAD_METHOD=inherit,
# для custom bot backup тоже.
UPLOAD_METHOD="s3"

# Telegram
BOT_TOKEN=""
CHAT_ID=""
MESSAGE_THREAD_ID=""

# S3
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PREFIX="rw-backup"
