# rw-backup-full v3 configuration
# This file is independent from original /opt/rw-backup-restore/config.env.
# Original config.env is used only by original rw-backup and can be imported as fallback for Telegram only if enabled below.

# Timer mode:
# backup-all     = panel + custom bots
# panel-backup   = only local Remnawave panel via original rw-backup, then duplicate latest panel archive to FULL external S3
# custom-backup  = only custom Docker bots from /home
FULL_TIMER_MODE="backup-all"
FULL_TIMER_INTERVAL_HOURS="3"

# Retention for full-created local custom archives and external S3 duplicates.
FULL_LOCAL_RETENTION_DAYS="3"
FULL_EXTERNAL_S3_RETENTION_DAYS="10"

# Original rw-backup behaviour.
# If true, install script/menu can fetch original distillium backup-restore.sh when missing.
FULL_AUTO_INSTALL_ORIGINAL_RW_BACKUP="false"
# If true, panel backup fails when original rw-backup is missing. If false, panel backup is skipped/failed softly depending command.
FULL_REQUIRE_ORIGINAL_RW_BACKUP="false"

# What to duplicate to FULL external S3.
FULL_PANEL_EXTERNAL_S3_ENABLED="true"
FULL_CUSTOM_EXTERNAL_S3_ENABLED="true"
FULL_INCLUDE_EXTRA_CONFIGS="true"

# Send a separate Telegram message for each file successfully saved to FULL external S3.
FULL_NOTIFY_EACH_EXTERNAL_S3_UPLOAD="true"

# Telegram for full notifications.
# If true, empty FULL_TG_* values are taken from original /opt/rw-backup-restore/config.env.
FULL_TELEGRAM_IMPORT_FROM_ORIGINAL="true"
FULL_TG_BOT_TOKEN=""
FULL_TG_CHAT_ID=""
FULL_TG_MESSAGE_THREAD_ID=""
FULL_TG_PROXY=""

# FULL external S3. This is independent from original rw-backup S3 settings.
# If FULL_EXTERNAL_S3_IMPORT_FROM_ORIGINAL=true, empty FULL_EXTERNAL_S3_* values are imported from original config.env.
# Recommended: keep false and configure a second bucket for duplication.
FULL_EXTERNAL_S3_IMPORT_FROM_ORIGINAL="false"
FULL_EXTERNAL_S3_BUCKET=""
FULL_EXTERNAL_S3_ACCESS_KEY=""
FULL_EXTERNAL_S3_SECRET_KEY=""
FULL_EXTERNAL_S3_REGION="us-east-1"
FULL_EXTERNAL_S3_ENDPOINT=""
FULL_EXTERNAL_S3_PREFIX="rw-backup-full"

# ===================== v4: WAL-архивация / PITR / песочница =====================

# Глобальный выключатель выгрузки WAL и базовых бэкапов в S3
# (используются те же FULL_EXTERNAL_S3_* реквизиты, что и выше).
FULL_WAL_S3_ENABLED="true"

# Публичный ключ age для шифрования базовых бэкапов и WAL (для инстансов
# с INST_ENCRYPT=true). Приватный ключ на сервере НЕ хранится.
#FULL_AGE_RECIPIENT="age1..."

# Расписание логических бэкапов (v3-таймер rw-backup-full.timer):
# ЛИБО интервал FULL_TIMER_INTERVAL_HOURS (выше), ЛИБО список конкретных времён.
# Список приоритетнее. Применить: rw-backup-full install-timer
#FULL_TIMER_TIMES="02:00 14:00"
# Часовой пояс для всех *_TIMES этого файла (пусто = локальный сервера):
#FULL_SCHEDULE_TZ="UTC"

# --- Песочница (обычно настраивается на ОТДЕЛЬНОМ сервере) ---
# Приватный ключ age для расшифровки при проверке (только на песочнице!).
#SANDBOX_AGE_IDENTITY="/root/.config/age/backup.key"
# Версия образа postgres для проверки логических дампов.
SANDBOX_PG_VERSION="17"
# Проверять ли логические архивы панели и ботов из S3.
SANDBOX_VERIFY_PANEL_LOGICAL="true"
SANDBOX_VERIFY_CUSTOM_LOGICAL="true"
# Слать ли Telegram-отчёт при полном успехе (при провале шлётся всегда).
SANDBOX_NOTIFY_ON_SUCCESS="true"
# Расписание проверок: список времён ИЛИ интервал в часах
# (по умолчанию ежедневно 05:30). Применить: rw-backup-full sandbox-timer
#SANDBOX_VERIFY_TIMES="05:30 17:30"
#SANDBOX_VERIFY_INTERVAL_HOURS="12"

# ===================== v5: единый движок, мульти-S3, метрики =====================

# Движок бэкапа панели: internal (встроенный, по умолчанию) | original (distillium).
FULL_PANEL_ENGINE="internal"

# Настройки панели (единые; при пустых берутся из оригинального config.env):
#PANEL_DB_CONTAINER="remnawave-db"
#PANEL_DB_USER="postgres"
#PANEL_ROOT_DIR="/opt/remnawave"
#PANEL_DB_VOLUME="remnawave-db-data"

# Отправлять ли сам архив панели документом в Telegram (лимит Bot API 50 МБ).
FULL_TG_SEND_PANEL_ARCHIVE="false"

# Считать ли объёмы в S3 (листинг бакетов) при экспорте метрик.
FULL_METRICS_S3_SIZES="true"

# ВНЕШНИЕ S3 ТЕПЕРЬ В s3.d/*.env (несколько бэкендов, у каждого свои retention).
# FULL_EXTERNAL_S3_* выше оставлены как legacy-fallback и мигрируются установщиком.
