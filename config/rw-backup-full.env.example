# ══════════════════════════════════════════════════════════════════════════
# rw-backup-full — ЕДИНЫЙ файл конфигурации
# /opt/rw-backup-restore/rw-backup-full.env
#
# Всё в одном месте: сюда переехали настройки, которые раньше читались из
# config.env оригинального distillium-скрипта. Зависимость от него убрана —
# панель бэкапится и восстанавливается собственным движком, формат архива
# при этом не изменился (архивы взаимно совместимы в обе стороны).
# ══════════════════════════════════════════════════════════════════════════

# ───────────────────────────── КОМПОНЕНТЫ ────────────────────────────────
# Что делает ЭТОТ сервер. Отключённые компоненты не ставят таймеров и не
# выполняют работу, даже если их скрипты установлены. Установщик спрашивает
# это интерактивно; поменять можно в любой момент, затем:
#   rw-backup-full apply-components
#
#   panel-backup   логический бэкап панели Remnawave (dump + каталог)
#   custom-backup  логический бэкап compose-проектов из /home
#   wal            непрерывная WAL-архивация PostgreSQL + PITR
#   config-track   непрерывный трекер каталогов (конфиги, код, ресурсы)
#   metrics        выгрузка метрик для Grafana
#   sandbox        проверка бэкапов (только на сервере-песочнице)
#   web            веб-сервис управления парком (только на песочнице)
FULL_COMPONENTS="panel-backup custom-backup wal config-track metrics"

# ────────────────────────────── ПАНЕЛЬ ───────────────────────────────────
PANEL_ROOT_DIR="/opt/remnawave"
PANEL_DB_CONTAINER="remnawave-db"
PANEL_CONTAINER="remnawave"
PANEL_DB_USER="postgres"
PANEL_DB_VOLUME="remnawave-db-data"
PANEL_EXCLUDES="*.log *.tmp .git"

# ───────────────────────────── РАСПИСАНИЯ ────────────────────────────────
# Для каждого таймера: ЛИБО интервал, ЛИБО список конкретных времён
# (любое количество, HH:MM или HH:MM:SS, через пробел/запятую).
# Список приоритетнее интервала. Применить: rw-backup-full install-timer

# Логические бэкапы (панель + боты). С включённым WAL и трекером конфигов
# их роль — переносимый снимок «всё целиком»; раз в несколько часов достаточно.
FULL_TIMER_INTERVAL_HOURS="6"
#FULL_TIMER_TIMES="03:00 15:00"

# Часовой пояс для всех *_TIMES этого файла (пусто = локальный сервера):
#FULL_SCHEDULE_TZ="UTC"

# Локальное хранение логических архивов, дней:
FULL_LOCAL_RETENTION_DAYS="3"

# ──────────────────────── ТРЕКЕР КАТАЛОГОВ ───────────────────────────────
# Отслеживает каталоги проектов ЦЕЛИКОМ (конфиги, .env, сертификаты, а у
# ботов — исполняемый код, миграции, шаблоны, ресурсы). Модель как у WAL:
# полный bundle = базовый бэкап, приращения = сегменты.
TRACK_INTERVAL_MIN="5"
TRACK_FULL_INTERVAL_HOURS="168"
TRACK_KEEP_FULL="4"
# Дополнительные исключения (к встроенным: .git, логи, node_modules,
# каталоги данных СУБД — они покрыты WAL и дампами, в трекере не нужны):
#TRACK_EXCLUDES="uploads cache"
#TRACK_ENCRYPT="false"

# ────────────────────────────── TELEGRAM ─────────────────────────────────
FULL_TG_BOT_TOKEN=""
FULL_TG_CHAT_ID=""
#FULL_TG_MESSAGE_THREAD_ID=""
#FULL_TG_PROXY=""
# Слать сам архив панели документом (лимит Bot API — 50 МБ):
FULL_TG_SEND_PANEL_ARCHIVE="false"
# Уведомлять о каждой удачной выгрузке в S3 (шумно при нескольких хранилищах):
FULL_NOTIFY_EACH_EXTERNAL_S3_UPLOAD="false"

# ────────────────────────── ВНЕШНИЕ ХРАНИЛИЩА ────────────────────────────
# Хранилищ может быть сколько угодно — по файлу на каждое в s3.d/<имя>.env,
# у каждого свои реквизиты, категории и сроки хранения:
#   rw-backup-full s3-add        добавить
#   rw-backup-full s3-backends   список
#   rw-backup-full s3-test       диагностика подключения
# Здесь указывать ничего не нужно.

# Шифрование age (публичный ключ; приватный на сервере НЕ хранится):
#FULL_AGE_RECIPIENT="age1..."

# ───────────────────────── WAL-АРХИВАЦИЯ / PITR ──────────────────────────
# Инстансы описываются отдельными файлами instances.d/<имя>.env — там же
# периодичность базовых бэкапов и отправки WAL.
# Примеры: /opt/rw-backup-restore/config-examples/instances.d/

# ──────────────────────────── МЕТРИКИ ────────────────────────────────────
FULL_METRICS_S3_SIZES="true"

# ─────────────────────── ПЕСОЧНИЦА (отдельный сервер) ────────────────────
#SANDBOX_AGE_IDENTITY="/root/.config/age/backup.key"
SANDBOX_PG_VERSION="17"
#SANDBOX_VERIFY_TIMES="05:30 17:30"
#SANDBOX_VERIFY_INTERVAL_HOURS="12"
SANDBOX_NOTIFY_ON_SUCCESS="true"
# Сколько секунд давать стеку на подъём в проверке verify-stack:
STACK_SETTLE_SECONDS="25"
