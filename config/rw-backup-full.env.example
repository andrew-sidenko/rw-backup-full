# /opt/rw-backup-restore/rw-backup-full.env
# Здесь хранятся только параметры надстройки rw-backup-full.
# Telegram/S3 параметры берутся из оригинального /opt/rw-backup-restore/config.env.

# inherit — взять способ отправки из оригинального config.env: UPLOAD_METHOD
# telegram — отправлять custom_bot backup в Telegram, используя BOT_TOKEN/CHAT_ID из config.env
# s3 — отправлять custom_bot backup в S3, используя S3_* из config.env
# both — Telegram + S3
# local — только локально
FULL_UPLOAD_METHOD="inherit"

# Каталог локального хранения backup.
FULL_BACKUP_DIR="/opt/rw-backup-restore/backup"

# Глубина хранения custom_bot_*.tar.gz локально.
FULL_LOCAL_RETENTION_DAYS="3"

# Глубина хранения custom_bot_*.tar.gz в S3.
FULL_S3_RETENTION_DAYS="10"

# Что запускать systemd timer-ом:
# custom-backup — только custom bot backup из /home
# backup-all — оригинальный panel backup + custom bot backup
FULL_TIMER_MODE="custom-backup"

# Интервал systemd timer-а в часах.
FULL_TIMER_INTERVAL_HOURS="3"

# true — если оригинальный rw-backup отсутствует, rw-backup-full попробует скачать его автоматически.
FULL_AUTO_INSTALL_RW_BACKUP="true"

# true — требовать наличие оригинального rw-backup.
# Для серверов только с ботами можно оставить true: скрипт сам скачает оригинальный rw-backup,
# а Telegram/S3 параметры будут храниться в оригинальном config.env.
FULL_REQUIRE_ORIGINAL_RW_BACKUP="true"

# Сохранять ли /opt/remnawave/caddy и /opt/remnawave/subscription как extra_configs.
FULL_INCLUDE_EXTRA_CONFIGS="true"

# Имя systemd unit/timer.
FULL_SYSTEMD_UNIT_NAME="rw-backup-full"
