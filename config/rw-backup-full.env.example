# rw-backup-full v3 configuration
# This file is independent from original /opt/rw-backup-restore/config.env.
# Original config.env is used only by original rw-backup and can be imported as fallback for Telegram only if enabled below.

# Timer mode:
# backup-all     = panel + custom bots
# panel-backup   = only local Remnawave panel via original rw-backup, then duplicate latest panel archive to FULL external S3
# custom-backup  = only custom Docker bots from /home
FULL_TIMER_MODE="backup-all"
FULL_TIMER_INTERVAL_HOURS="3"

# Retention for full-created local custom archives and external S3 duplicates.
FULL_LOCAL_RETENTION_DAYS="3"
FULL_EXTERNAL_S3_RETENTION_DAYS="10"

# Original rw-backup behaviour.
# If true, install script/menu can fetch original distillium backup-restore.sh when missing.
FULL_AUTO_INSTALL_ORIGINAL_RW_BACKUP="false"
# If true, panel backup fails when original rw-backup is missing. If false, panel backup is skipped/failed softly depending command.
FULL_REQUIRE_ORIGINAL_RW_BACKUP="false"

# What to duplicate to FULL external S3.
FULL_PANEL_EXTERNAL_S3_ENABLED="true"
FULL_CUSTOM_EXTERNAL_S3_ENABLED="true"
FULL_INCLUDE_EXTRA_CONFIGS="true"

# Send a separate Telegram message for each file successfully saved to FULL external S3.
FULL_NOTIFY_EACH_EXTERNAL_S3_UPLOAD="true"

# Telegram for full notifications.
# If true, empty FULL_TG_* values are taken from original /opt/rw-backup-restore/config.env.
FULL_TELEGRAM_IMPORT_FROM_ORIGINAL="true"
FULL_TG_BOT_TOKEN=""
FULL_TG_CHAT_ID=""
FULL_TG_MESSAGE_THREAD_ID=""
FULL_TG_PROXY=""

# FULL external S3. This is independent from original rw-backup S3 settings.
# If FULL_EXTERNAL_S3_IMPORT_FROM_ORIGINAL=true, empty FULL_EXTERNAL_S3_* values are imported from original config.env.
# Recommended: keep false and configure a second bucket for duplication.
FULL_EXTERNAL_S3_IMPORT_FROM_ORIGINAL="false"
FULL_EXTERNAL_S3_BUCKET=""
FULL_EXTERNAL_S3_ACCESS_KEY=""
FULL_EXTERNAL_S3_SECRET_KEY=""
FULL_EXTERNAL_S3_REGION="us-east-1"
FULL_EXTERNAL_S3_ENDPOINT=""
FULL_EXTERNAL_S3_PREFIX="rw-backup-full"
