# Профиль для типа "site" (пример: сайт/CMS). Скопируйте в site.env и правьте.
# Тип инстанса задаётся в instances.d/<имя>.env: INST_KIND="site"
PROFILE_REQUIRED_TABLES=""
PROFILE_MIN_TABLES="3"
PROFILE_MIN_TOTAL_ROWS="50"
PROFILE_CHECK_QUERIES="
контент::SELECT count(*) FROM posts::1
"
PROFILE_DEEP_AMCHECK="false"
