# Профиль проверок для типа "panel" (панель Remnawave).
# Применяется песочницей к восстановленной БД этого типа.

# Таблицы, которые обязаны существовать и быть непустыми
# (дополняются INST_VERIFY_TABLES конкретного инстанса):
PROFILE_REQUIRED_TABLES="public.users public.nodes"

# Минимум пользовательских таблиц в восстановленной БД:
PROFILE_MIN_TABLES="5"
# Минимум суммарных строк (детект «пустой, но поднявшейся» базы):
PROFILE_MIN_TOTAL_ROWS="10"

# Дополнительные SQL-проверки: "имя::SQL (должен вернуть число)::минимум"
# По строке на проверку; расширяйте под свои гарантии.
PROFILE_CHECK_QUERIES="
активные_ноды::SELECT count(*) FROM nodes::1
пользователи::SELECT count(*) FROM users::1
"

# Глубокая проверка (depth=deep): pg_amcheck по всем БД.
PROFILE_DEEP_AMCHECK="true"
