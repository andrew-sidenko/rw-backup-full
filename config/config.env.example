# ==========================================================
# rw-backup-full example config
# File path on server: /opt/rw-backup-restore/config.env
# ==========================================================

# telegram | s3 | both | local
UPLOAD_METHOD="telegram"

# Local retention for custom_bot_*.tar.gz
RETAIN_BACKUPS_DAYS=3
LOCAL_RETENTION_DAYS=3

# S3 retention for custom_bot_*.tar.gz
S3_RETENTION_DAYS=10
S3_RETAIN_DAYS=10

# Telegram settings.
# Compatible aliases: BOT_TOKEN/CHAT_ID/MESSAGE_THREAD_ID or TG_*/TELEGRAM_*.
BOT_TOKEN=""
CHAT_ID=""
MESSAGE_THREAD_ID=""
# TELEGRAM_PROXY=""

# S3 settings.
# For AWS S3 leave S3_ENDPOINT empty.
# For S3-compatible providers set S3_ENDPOINT, for example https://s3.timeweb.cloud
S3_BUCKET=""
S3_ACCESS_KEY=""
S3_SECRET_KEY=""
S3_REGION="us-east-1"
S3_ENDPOINT=""
S3_PREFIX="rw-backup"

# Optional: path to original rw-backup binary/script.
# ORIGINAL_RW_BACKUP_BIN="rw-backup"
# ORIGINAL_RW_BACKUP_SCRIPT is derived from INSTALL_DIR and normally does not need to be set.
