{
  "title": "rw-backup-full — бэкапы, WAL, песочница",
  "uid": "rw-backup-full",
  "tags": [
    "rw-backup-full",
    "backups"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "1m",
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "DS",
        "label": "Источник данных",
        "type": "datasource",
        "query": "prometheus",
        "current": {}
      }
    ]
  },
  "annotations": {
    "list": []
  },
  "panels": [
    {
      "id": 1,
      "title": "Бэкап панели: результат",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "max by (instance) (rw_panel_backup_last_result)",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background"
      }
    },
    {
      "id": 2,
      "title": "Базовые бэкапы: результат",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 6,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "min by (host) (label_replace(rw_basebackup_last_result, \"host\", \"$1\", \"instance\", \"(.*)\"))",
          "legendFormat": "все инстансы (min)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background"
      }
    },
    {
      "id": 3,
      "title": "Песочница: проверок пройдено",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "rw_sandbox_checks_passed",
          "legendFormat": "пройдено",
          "refId": "A"
        },
        {
          "expr": "rw_sandbox_checks_total",
          "legendFormat": "всего",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "textMode": "value_and_name"
      }
    },
    {
      "id": 4,
      "title": "Возраст последнего panel-бэкапа",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 18,
        "y": 0,
        "w": 6,
        "h": 5
      },
      "targets": [
        {
          "expr": "time() - rw_panel_backup_last_success_timestamp_seconds",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 21600
              },
              {
                "color": "red",
                "value": 43200
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 10,
      "title": "WAL: сегментов в спуле (рост = проблема)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_wal_spool_files",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 11,
      "title": "WAL: возраст последнего базового бэкапа",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 8,
        "y": 5,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "time() - rw_basebackup_last_success_timestamp_seconds",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 12,
      "title": "Песочница: PITR-проверки по инстансам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 16,
        "y": 5,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_sandbox_pitr_last_ok",
          "legendFormat": "{{instance}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          },
          "max": 1,
          "min": 0
        },
        "overrides": []
      }
    },
    {
      "id": 20,
      "title": "Размеры бэкапов (локально)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_panel_backup_size_bytes",
          "legendFormat": "панель (последний)",
          "refId": "A"
        },
        {
          "expr": "sum by (category) (rw_local_archives_bytes)",
          "legendFormat": "локально: {{category}}",
          "refId": "B"
        },
        {
          "expr": "sum by (instance) (rw_wal_local_bytes)",
          "legendFormat": "WAL: {{instance}}",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 21,
      "title": "S3: объём по бэкендам и категориям",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 8,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "sum by (backend, category) (rw_s3_category_bytes)",
          "legendFormat": "{{backend}}/{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        },
        "overrides": []
      }
    },
    {
      "id": 22,
      "title": "Свободное место на серверах",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 16,
        "y": 12,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_disk_free_bytes",
          "legendFormat": "{{role}} {{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 5000000000.0
              },
              {
                "color": "green",
                "value": 20000000000.0
              }
            ]
          }
        },
        "overrides": []
      }
    },
    {
      "id": 30,
      "title": "Длительность операций",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 19,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_basebackup_duration_seconds",
          "legendFormat": "basebackup {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rw_sandbox_pitr_duration_seconds",
          "legendFormat": "pitr-verify {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      }
    },
    {
      "id": 31,
      "title": "Доступность S3-бэкендов",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 8,
        "y": 19,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_s3_backend_reachable",
          "legendFormat": "{{backend}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 60
          }
        },
        "overrides": []
      }
    },
    {
      "id": 32,
      "title": "Ошибки: WAL-ship и pending S3",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 16,
        "y": 19,
        "w": 8,
        "h": 7
      },
      "targets": [
        {
          "expr": "rw_wal_ship_failures",
          "legendFormat": "ship-ошибки {{instance}}",
          "refId": "A"
        },
        {
          "expr": "rw_wal_s3_pending",
          "legendFormat": "pending S3 {{instance}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 40,
      "title": "Песочница: логические архивы (panel / custom-bot)",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 26,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rw_sandbox_logical_last_ok",
          "legendFormat": "{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        },
        "overrides": []
      }
    },
    {
      "id": 41,
      "title": "Количество хранимых базовых бэкапов",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 26,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rw_basebackup_count",
          "legendFormat": "{{instance}}/{{location}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      }
    },
    {
      "id": 50,
      "title": "Источники бэкапов (хосты и k8s)",
      "type": "table",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 32,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rw_source_info",
          "format": "table",
          "instant": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": []
      },
      "options": {}
    },
    {
      "id": 51,
      "title": "Песочница: логические проверки по источникам",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 12,
        "y": 32,
        "w": 12,
        "h": 6
      },
      "targets": [
        {
          "expr": "rw_sandbox_logical_last_ok",
          "legendFormat": "{{source}}/{{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80
          }
        },
        "overrides": []
      }
    },
    {
      "id": 60,
      "title": "Fleet-verify: сервер × хранилище × категория",
      "type": "state-timeline",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 0,
        "y": 38,
        "w": 16,
        "h": 8
      },
      "targets": [
        {
          "expr": "rw_fleet_verify_ok",
          "legendFormat": "{{source}} × {{backend}} × {{category}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "max": 1,
          "min": 0,
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "FAIL",
                  "color": "red"
                },
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ]
        },
        "overrides": []
      }
    },
    {
      "id": 61,
      "title": "Доступность серверов для проверки",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "${DS}"
      },
      "gridPos": {
        "x": 16,
        "y": 38,
        "w": 8,
        "h": 8
      },
      "targets": [
        {
          "expr": "rw_fleet_server_reachable",
          "legendFormat": "{{server}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "OFFLINE",
                  "color": "red"
                },
                "1": {
                  "text": "OK",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "background"
      }
    }
  ]
}